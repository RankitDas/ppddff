# Max upload size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800

# Directory for temporary working files
TMP_DIR=/tmp/ppddff

# Minutes before a temp file is force-deleted by the sweeper
TMP_TTL_MINUTES=15

# Path to the LibreOffice headless binary (soffice)
LIBREOFFICE_BIN=soffice

# Puppeteer: reuse a system Chromium instead of the bundled one (optional)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium